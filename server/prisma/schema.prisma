generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum GradeLevel {
  KINDERGARTEN
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
  GRADE_6
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_10
  GRADE_11
  GRADE_12
  UNDERGRAD
  GRADUATE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  username         String     @unique
  passwordHash     String
  dateOfBirth      DateTime
  gradeLevel       GradeLevel
  role             Role       @default(USER)
  // Every new account gets a 1-day full-access trial (no card required)
  trialEndsAt      DateTime
  stripeCustomerId String?    @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  xp                  Int                  @default(0)
  coins               Int                  @default(0)
  avatarColor         String               @default("#6B21D6")

  subscription        Subscription?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  progress            UserProgress[]
  quizAttempts        QuizAttempt[]
  xpEvents            XpEvent[]
  friendsRequested    Friendship[]         @relation("requester")
  friendsReceived     Friendship[]         @relation("addressee")
  cosmetics           UserCosmetic[]
  achievements        UserAchievement[]
  crateOpens          CrateOpen[]
  notes               Note[]
  flashcards          Flashcard[]
  formulaStars        FormulaStar[]
  notifications       Notification[]
  challengeClaims     ChallengeClaim[]

  @@index([email])
  @@index([username])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // friend_request, achievement, battle, store, system
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model ChallengeClaim {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          String // "YYYY-MM-DD" (UTC) for daily, "YYYY-Www" for weekly
  challengeKey String
  createdAt    DateTime @default(now())

  @@unique([userId, day, challengeKey])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model Flashcard {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck           String
  front          String
  back           String
  source         String    @default("custom") // custom | lesson:<slug>
  // SM-2 spaced repetition
  ease           Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, deck])
  @@index([userId, dueAt])
}

model FormulaStar {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ref       String // "<lessonSlug>#<index>"
  createdAt DateTime @default(now())

  @@unique([userId, ref])
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum CosmeticType {
  TITLE
  BADGE
  OUTFIT
  HAT
  AURA
  PET
  BACKGROUND
}

model Cosmetic {
  id          String         @id @default(cuid())
  key         String         @unique
  name        String
  type        CosmeticType
  rarity      Rarity
  description String
  // Crate pool tags, e.g. ["explorer","scholar"]; empty = direct-purchase only
  crates      String[]       @default([])
  coinPrice   Int            @default(0) // direct purchase price (0 = not directly sold)
  owners      UserCosmetic[]
}

model UserCosmetic {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmeticId String
  cosmetic   Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)
  equipped   Boolean  @default(false)
  acquiredAt DateTime @default(now())

  @@unique([userId, cosmeticId])
  @@index([userId])
}

model CrateOpen {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  crateKey  String
  rarity    Rarity
  createdAt DateTime @default(now())

  @@index([userId, crateKey])
}

enum AchievementCategory {
  EXPLORER
  SCHOLAR
  STREAK
  PERFECT
  SOCIAL
  CALCULATOR
  COLLECTOR
  LEGENDARY
}

model Achievement {
  id          String              @id @default(cuid())
  key         String              @unique
  name        String
  description String
  category    AchievementCategory
  xpReward    Int                 @default(0)
  coinReward  Int                 @default(0)
  threshold   Int                 @default(1) // count needed (e.g. 7 lessons)
  metric      String // which stat to compare: lessonsCompleted, battlesWon, ...
  secret      Boolean             @default(false)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  requester   User         @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model BattleMatch {
  id        String   @id @default(cuid())
  playerAId String
  playerBId String
  winnerId  String? // null = draw
  scoreA    Int
  scoreB    Int
  subject   String   @default("MIXED")
  ranked    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([playerAId])
  @@index([playerBId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  plan                 SubscriptionPlan
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────── Phase 2: Physics Journey ───────────────────────────

enum SectionKind {
  HERO
  CONTEXT
  CONCEPT
  SIMULATION
  WORKED_EXAMPLES
  VIDEOS
  CONCEPT_CHECK
  PRACTICE
  DEEPER_DIVE
  SUMMARY
}

enum QuestionScope {
  CONCEPT_CHECK
  PRACTICE
}

enum QuestionKind {
  MCQ
  TRUE_FALSE
  NUMERIC
}

enum ProgressStatus {
  STARTED
  COMPLETED
  MASTERED
}

enum Subject {
  PHYSICS
  MATH
}

model World {
  id          String   @id @default(cuid())
  slug        String   @unique
  subject     Subject  @default(PHYSICS)
  name        String
  subtitle    String
  description String
  orderIndex  Int
  gradeRange  String // e.g. "K–2"
  scaleLabel  String // e.g. "3×10⁶ m"
  palette     Json // { accent, glow }
  lessons     Lesson[]

  @@unique([subject, orderIndex])
}

model Lesson {
  id         String          @id @default(cuid())
  worldId    String
  world      World           @relation(fields: [worldId], references: [id], onDelete: Cascade)
  slug       String          @unique
  title      String
  tagline    String
  orderIndex Int
  xpReward   Int             @default(100)
  estMinutes Int             @default(12)
  published  Boolean         @default(true)
  sections   LessonSection[]
  questions  QuizQuestion[]
  progress   UserProgress[]
  attempts   QuizAttempt[]
  xpEvents   XpEvent[]
  notes      Note[]

  @@unique([worldId, orderIndex])
}

model LessonSection {
  id         String      @id @default(cuid())
  lessonId   String
  lesson     Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  kind       SectionKind
  orderIndex Int
  title      String?
  content    Json // shape varies by kind — see seed data

  @@unique([lessonId, orderIndex])
}

model QuizQuestion {
  id          String        @id @default(cuid())
  lessonId    String
  lesson      Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  scope       QuestionScope
  orderIndex  Int
  kind        QuestionKind
  prompt      String // markdown, KaTeX allowed
  options     Json? // MCQ: string[]
  answer      Json // MCQ: index · TRUE_FALSE: boolean · NUMERIC: { value, tolerance }
  hint        String?
  explanation String

  @@index([lessonId, scope])
}

model QuizAttempt {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  scope     QuestionScope
  score     Int
  total     Int
  answers   Json
  createdAt DateTime      @default(now())

  @@index([userId, lessonId, scope])
}

model UserProgress {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status       ProgressStatus @default(STARTED)
  bestScore    Int? // best practice score, percent
  timeSpentSec Int            @default(0)
  attempts     Int            @default(0)
  // Distinct dates ("YYYY-MM-DD") with a ≥90% practice score; 2 dates ⇒ MASTERED
  masteryDays  Json           @default("[]")
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, lessonId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String // LESSON_COMPLETE, QUIZ_PERFECT, ...
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@unique([userId, reason, lessonId])
}

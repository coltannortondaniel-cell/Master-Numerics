T* (                    "problem": "Why is relativity invisible in daily life?",) Tj
T* (                    "steps": [) Tj
T* (                      "Everyday $v \\\\ll c$.",) Tj
T* (                      "Then $v^2/c^2 \\\\approx 0$ and $\\\\gamma \\\\approx 1$.") Tj
T* (                    ],) Tj
T* (                    "answer": "Effects are negligible at ordinary speeds.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "Rest energy",) Tj
T* (                    "problem": "What does $E = mc^2$ say about a mass at rest?",) Tj
T* (                    "steps": [) Tj
T* (                      "Even at rest, mass has energy.",) Tj
T* (                      "$E = mc^2$.") Tj
T* (                    ],) Tj
T* (                    "answer": "Mass is concentrated energy.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "The cosmic limit",) Tj

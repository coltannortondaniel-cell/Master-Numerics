T* (                      "6 cups flour is $3\\\\times$ the flour.",) Tj
T* (                      "Sugar scales the same: $3 \\\\times 1 = 3$.") Tj
T* (                    ],) Tj
T* (                    "answer": "3 cups of sugar.") Tj

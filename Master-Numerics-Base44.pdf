T* (              "prompt": "About how long does one full day-night cycle last on the Moon?",) Tj
T* (              "options": [) Tj
T* (                "24 hours",) Tj
T* (                "One week",) Tj
T* (                "About 29.5 Earth days",) Tj
T* (                "One year") Tj
T* (              ],) Tj
T* (              "answer": 2,) Tj
T* (              "explanation": "The Moon spins very slowly -- one full cycle takes about 29.5 Earth days, with roughly two) Tj
T* ( weeks of daylight.") Tj

T* (                    "steps": [) Tj
T* (                      "Classically they can't overcome repulsion.",) Tj
T* (                      "Their wave nature lets a few tunnel through.") Tj
T* (                    ],) Tj
T* (                    "answer": "Quantum tunnelling enables fusion.") Tj
T* (                  },) Tj

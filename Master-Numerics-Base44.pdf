T* (                "intro": "Mean adds and divides; median is the middle.") Tj
T* (              }) Tj
T* (            },) Tj
T* (            {) Tj
T* (              "kind": "PRACTICE",) Tj
T* (              "title": "Practice problems",) Tj
T* (              "content": {) Tj
T* (                "intro": "Sort first for the median.") Tj
T* (              }) Tj
T* (            },) Tj

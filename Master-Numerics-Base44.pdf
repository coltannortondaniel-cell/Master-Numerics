T* (                      "Divide by 3: $2 : 5$.") Tj
T* (                    ],) Tj
T* (                    "answer": "$6 : 15 = 2 : 5$.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "Keep the ratio",) Tj

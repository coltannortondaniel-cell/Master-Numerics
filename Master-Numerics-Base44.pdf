T* (          "slug": "newtons-second-law",) Tj
T* (          "title": "Newton's Second Law -- F = ma",) Tj
T* (          "tagline": "Force, mass, and acceleration in one equation",) Tj
T* (          "estMinutes": 16,) Tj

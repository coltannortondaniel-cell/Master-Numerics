T* (                    "steps": [) Tj
T* (                      "Protons repel electromagnetically.",) Tj
T* (                      "The strong force is stronger at short range.") Tj
T* (                    ],) Tj
T* (                    "answer": "The strong force.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "Weakest yet dominant",) Tj
T* (                    "problem": "How can gravity rule the cosmos while being the weakest force?",) Tj
T* (                    "steps": [) Tj
T* (                      "Gravity is always attractive and never cancels.",) Tj
T* (                      "Charges mostly balance out at large scale.") Tj

T* (          "slug": "forms-of-energy",) Tj
T* (          "title": "Energy and Its Many Forms",) Tj
T* (          "tagline": "The one thing that's never created or destroyed",) Tj
T* (          "estMinutes": 16,) Tj
T* (          "xpReward": 140,) Tj
T* (          "difficulty": 3,) Tj
T* (          "sections": [) Tj

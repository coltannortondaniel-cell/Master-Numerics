T* (          "slug": "temperature-and-thermal-energy",) Tj
T* (          "title": "Temperature and Thermal Energy",) Tj
T* (          "tagline": "Heat is jiggling -- and there's a coldest possible cold",) Tj
T* (          "estMinutes": 15,) Tj

T* (                    "steps": [) Tj
T* (                      "Terms shrink toward 0.",) Tj
T* (                      "For any $\\\\varepsilon$, take $N > 1/\\\\varepsilon$.") Tj
T* (                    ],) Tj
T* (                    "answer": "$0$.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "Rewrite to see it",) Tj
T* (                    "problem": "Find $\\\\lim_{n\\\\to\\\\infty}\\\\dfrac{n+1}{n}$.",) Tj
T* (                    "steps": [) Tj
T* (                      "$= 1 + \\\\dfrac1n$.",) Tj
T* (                      "$\\\\dfrac1n \\\\to 0$.") Tj
T* (                    ],) Tj
T* (                    "answer": "$1$.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "Divergence",) Tj
T* (                    "problem": "Does $a_n = \(-1\)^n$ converge?",) Tj

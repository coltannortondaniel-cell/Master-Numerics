T* (                      "Always hot -> cold.",) Tj
T* (                      "Until equal temperature.") Tj
T* (                    ],) Tj
T* (                    "answer": "From hot to cold.") Tj
T* (                  },) Tj
T* (                  {) Tj
T* (                    "title": "Boyle's behavior",) Tj

T* (                  {) Tj
T* (                    "title": "Evaluate",) Tj
T* (                    "problem": "For $f\(x\) = 2^x$, find $f\(3\)$.",) Tj
T* (                    "steps": [) Tj
T* (                      "$2^3$.",) Tj
T* (                      "$= 8$.") Tj
T* (                    ],) Tj
ET

T* (                      "Area $= l w = 5 \\\\times 3 = 15$.",) Tj
T* (                      "Perimeter $= 2\(5+3\) = 16$.") Tj
T* (                    ],) Tj
T* (                    "answer": "Area $15\\\\,\\\\text{m}^2$, perimeter $16\\\\,\\\\text{m}$.") Tj
T* (                  },) Tj
T* (                  {) Tj

T* (                    "problem": "A $50\\\\,\\\\text{N}$ force pushes for $4.0\\\\,\\\\text{s}$. Find the impulse.",) Tj
T* (                    "steps": [) Tj
T* (                      "$J = F\\\\,\\\\Delta t = 50 \\\\times 4.0$.",) Tj
T* (                      "$= 200\\\\,\\\\text{N*s}$.") Tj

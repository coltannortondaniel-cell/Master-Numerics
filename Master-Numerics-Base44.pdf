T* (                    "title": "Newton's First Law of Motion") Tj
T* (                  }) Tj
T* (                ]) Tj
T* (              }) Tj
T* (            },) Tj
T* (            {) Tj
T* (              "kind": "CONCEPT_CHECK",) Tj
T* (              "title": "Quick check",) Tj
T* (              "content": {) Tj

T* (          "slug": "pythagorean-theorem",) Tj
T* (          "title": "The Pythagorean Theorem",) Tj
T* (          "tagline": "The rule of right triangles",) Tj
T* (          "estMinutes": 15,) Tj
T* (          "xpReward": 160,) Tj
T* (          "difficulty": 4,) Tj
T* (          "sections": [) Tj
T* (            {) Tj

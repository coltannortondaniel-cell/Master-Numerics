T* (                  "Decimal -> percent: x100; percent -> decimal: /100.",) Tj
T* (                  "Anchors: $\\\\tfrac12=0.5=50\\\\%$, $\\\\tfrac14=0.25=25\\\\%$, $\\\\tfrac34=0.75=75\\\\%$.") Tj
T* (                ],) Tj

T* (                  "Distance is total path length: a non-negative scalar.",) Tj
T* (                  "$\\\\text{distance} \\\\ge |\\\\Delta x|$, equal only if motion never reverses.") Tj
T* (                ],) Tj
T* (                "formulas": [) Tj
T* (                  {) Tj
T* (                    "label": "Displacement",) Tj

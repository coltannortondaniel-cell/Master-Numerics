T* (  questions: [ Question, ... ]) Tj
T* (}) Tj
T* () Tj
T* (Section = { kind, title?, content }  // kind ?) Tj
T* (  HERO            content: { scene, headline, sub }) Tj
T* (  CONTEXT         content: { markdown }) Tj
T* (  CONCEPT         content: { markdown }) Tj
T* (  SIMULATION      content: { simId, intro }            // interactive mini-sim by id) Tj
T* (  WORKED_EXAMPLES content: { examples: [{ title, problem, steps[], answer }] }) Tj
T* (  VIDEOS          content: { videos: [{ youtubeId, title }] }   // embed these) Tj
T* (  CONCEPT_CHECK   content: { intro }                   // shows scope=CONCEPT_CHECK Qs) Tj
T* (  PRACTICE        content: { intro }                   // shows scope=PRACTICE Qs) Tj
T* (  DEEPER_DIVE     content: { markdown }) Tj
T* (  SUMMARY         content: { takeaways: [string], formulas: [{ label, tex }] }) Tj
T* () Tj
T* (Question = {) Tj
T* (  scope: "CONCEPT_CHECK" | "PRACTICE",) Tj
T* (  kind: "MCQ"|"TRUE_FALSE"|"NUMERIC"|"MATCHING"|"FILL_BLANK"|"ORDER"|"PROOF"|"SYMBOLIC"|"GRAPH",) Tj
T* (  prompt, options?, answer, difficulty? \(1-5\), hint?, explanation) Tj
T* (}) Tj
T* (// answer by kind:) Tj
T* (//   MCQ -> correct index \(number\)        TRUE_FALSE -> boolean) Tj
T* (//   NUMERIC -> { value, tolerance }      MATCHING -> right[] in left order) Tj
T* (//   FILL_BLANK -> string[][] \(accepted strings per blank\)) Tj
T* (//   ORDER/PROOF -> [] \(options already in correct order; learner reorders\)) Tj
T* (//   SYMBOLIC -> { expr, vars?, tolerance? }) Tj
T* (//   GRAPH -> { expr, domain?, variable?, tolerance?, mode?, samples? }) Tj
T* (//           mode:"draw" => render a sketch-the-curve canvas instead of a text field) Tj
T* (```) Tj
